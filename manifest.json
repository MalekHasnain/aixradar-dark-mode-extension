{
  "manifest_version": 3,
  "name": "Dark Mode Toggle - Night Eye",
  "version": "1.0.0",
  "description": "Instantly enable dark mode on any website. Easy toggle, site-specific settings, and smart contrast for comfortable browsing day or night.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["dark-mode.css"],
      "run_at": "document_start"
    }
  ]
}